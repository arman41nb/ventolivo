generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id                    Int      @id @default(autoincrement())
  name                  String
  slug                  String   @unique
  tag                   String
  price                 Int
  color                 String
  description           String
  ingredients           String?
  weight                String?
  featured              Boolean  @default(false)
  nameTranslations      String?
  tagTranslations       String?
  descriptionTranslations String?
  weightTranslations    String?
  ingredientsTranslations String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  mediaLinks            ProductMedia[]
  buyerIntents          BuyerIntent[]

  @@index([tag])
  @@index([slug])
  @@index([featured])
}

model MediaAsset {
  id           String         @id @default(cuid())
  kind         String
  url          String
  altText      String?
  thumbnailUrl String?
  label        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  productLinks ProductMedia[]
}

model ProductMedia {
  id           String     @id @default(cuid())
  productId    Int
  mediaAssetId String
  role         String
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@index([mediaAssetId])
}

model SiteContentSettings {
  id                  Int      @id
  brandName           String
  logoMode            String
  logoText            String
  logoImageUrl        String?
  logoAltText         String?
  contentJson         String?
  navbarCtaLabel      String
  heroSubtitle        String
  heroTitleLine1      String
  heroTitleLine2      String
  heroTitleLine3      String
  heroDescription     String
  heroBadgeValue      String
  heroBadgeLabel      String
  heroImageUrl        String?
  heroImageAlt        String?
  ctaTitleLine1       String
  ctaTitleLine2       String
  ctaDescription      String
  ctaButtonLabel      String
  footerCopyrightText String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  translations        SiteContentTranslation[]
}

model SiteContentTranslation {
  id                  String              @id @default(cuid())
  siteContentId       Int
  locale              String
  contentJson         String?
  navbarCtaLabel      String?
  heroSubtitle        String?
  heroTitleLine1      String?
  heroTitleLine2      String?
  heroTitleLine3      String?
  heroDescription     String?
  heroBadgeValue      String?
  heroBadgeLabel      String?
  ctaTitleLine1       String?
  ctaTitleLine2       String?
  ctaDescription      String?
  ctaButtonLabel      String?
  footerCopyrightText String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  siteContent         SiteContentSettings @relation(fields: [siteContentId], references: [id], onDelete: Cascade)

  @@unique([siteContentId, locale])
  @@index([locale])
}

model AdminUser {
  id           Int            @id @default(autoincrement())
  username     String         @unique
  email        String?        @unique
  displayName  String?
  role         String         @default("owner")
  status       String         @default("active")
  passwordHash String
  lastLoginAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]
  auditLogs    AuditLog[]
}

model AdminSession {
  id          String    @id @default(cuid())
  adminUserId Int
  tokenHash   String
  ipAddress   String?
  userAgent   String?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  adminUser   AdminUser  @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([expiresAt])
}

model AuditLog {
  id          String     @id @default(cuid())
  action      String
  adminUserId Int?
  actorLabel  String?
  targetType  String?
  targetId    String?
  metadata    String?
  createdAt   DateTime   @default(now())
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId])
  @@index([createdAt])
  @@index([action])
}

model CustomerUser {
  id               Int               @id @default(autoincrement())
  email            String            @unique
  fullName         String
  avatarUrl        String?
  phone            String?
  status           String            @default("active")
  passwordHash     String
  marketingConsent Boolean           @default(false)
  lastLoginAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  sessions         CustomerSession[]
  buyerIntents     BuyerIntent[]
}

model CustomerSession {
  id             String       @id @default(cuid())
  customerUserId Int
  tokenHash      String
  ipAddress      String?
  userAgent      String?
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  customerUser   CustomerUser @relation(fields: [customerUserId], references: [id], onDelete: Cascade)

  @@index([customerUserId])
  @@index([expiresAt])
}

model BuyerIntent {
  id             String        @id @default(cuid())
  customerUserId Int?
  productId      Int?
  locale         String
  channel        String        @default("whatsapp")
  source         String?
  note           String?
  createdAt      DateTime      @default(now())
  customerUser   CustomerUser? @relation(fields: [customerUserId], references: [id], onDelete: SetNull)
  product        Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([customerUserId])
  @@index([productId])
  @@index([createdAt])
  @@index([locale])
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?
  phone     String?
  message   String
  productId Int?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read])
  @@index([createdAt])
}

model RateLimitBucket {
  id         String   @id @default(cuid())
  scope      String
  identifier String
  count      Int      @default(0)
  resetAt    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([scope, identifier])
  @@index([resetAt])
}

model BlogPost {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  summary     String
  content     String
  tags        String?
  coverImage  String?
  coverAlt    String?
  seoTitle    String?
  seoDescription String?
  status      String   @default("draft")
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([status, publishedAt])
  @@index([createdAt])
}
